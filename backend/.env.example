# POS-Pricing Navigator Backend — env example
# 실제 키는 .env (gitignore) 에 기록. 운영은 Secret Manager 권장.

# ── App ────────────────────────────────────────
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=3001
APP_TIMEZONE=Asia/Seoul
APP_LOG_LEVEL=INFO

# ── PostgreSQL ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pos:pos@localhost:5433/pos_pricing_navigator

# ── Redis ──────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT / Auth ─────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MIN=480

# ── LLM (Anthropic Claude Haiku 4.5) ───────────
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
LLM_TIMEOUT_SEC=30
LLM_MAX_TOKENS=2048

# ── External News APIs ─────────────────────────
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NEWSAPI_KEY=

# ── Public Data ────────────────────────────────
NARA_API_KEY=

# ── Google (optional) ──────────────────────────
GOOGLE_CREDENTIALS_PATH=

# ── Cache TTL ──────────────────────────────────
CACHE_TTL_ANALYSIS_SEC=86400
CACHE_TTL_CHAT_SEC=1800
REFRESH_DEBOUNCE_SEC=5

# ── Batch ──────────────────────────────────────
BATCH_CRON_HOUR=6
BATCH_CRON_MINUTE=0
